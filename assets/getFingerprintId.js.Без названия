/* globals FingerprintJS */

define('getFingerprintId', ['fingerprint'], function (Fingerprint) {
    'use strict';

    var getFingerprint = function () {
      return Fingerprint.load().then(fp => fp.get());
    };

    var getFingerprintPro = function (token) {
      return new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.onload = resolve;
        script.onerror = reject;
        script.async = true;
        script.src = 'https://cdn.jsdelivr.net/npm/@fingerprintjs/fingerprintjs-pro@3/dist/fp.min.js';
        document.head.appendChild(script);
      })
      .then(() => FingerprintJS.load({
        token: token, region: 'eu'
      }))
      .then(fp => fp.get());
    };
    return { getFingerprint, getFingerprintPro };
});
